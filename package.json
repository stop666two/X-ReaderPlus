{
  "name": "x-reader-plus",
  "version": "0.3.0",
  "description": "完全脱机的现代化多格式阅读器",
  "author": "stop666",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stop666two/X-ReaderPlus.git"
  },
  "bugs": {
    "url": "https://github.com/stop666two/X-ReaderPlus/issues"
  },
  "homepage": "https://github.com/stop666two/X-ReaderPlus",
  "keywords": [
    "ebook-reader",
    "vue",
    "offline",
    "epub",
    "pdf",
    "reader"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:go": "cd backend && go run .",
    "build": "vite build",
    "build:go": "node scripts/copy-frontend.js && cd backend && go build -ldflags=\"-s -w -H=windowsgui\" -o ../dist/X-ReaderPlus.exe .",
    "build:go:dev": "cd backend && go build -ldflags=\"-s -w\" -o ../dist/X-ReaderPlus-dev.exe .",
    "build:all": "vite build && npm run build:go",
    "preview": "vite preview",
    "lint": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "dayjs": "^1.11.13",
    "dompurify": "^3.2.4",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "marked": "^15.0.12",
    "pdfjs-dist": "^4.0.379",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-i18n": "^11.1.1",
    "vue-router": "^4.5.1",
    "vuetify": "^3.8.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "~5.7.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.12"
  }
}
