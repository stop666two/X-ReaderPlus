{
  "name": "x-reader-plus",
  "version": "0.5.0",
  "description": "完全脱机的现代化多格式阅读器",
  "author": "stop666",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stop666two/X-ReaderPlus.git"
  },
  "bugs": {
    "url": "https://github.com/stop666two/X-ReaderPlus/issues"
  },
  "homepage": "https://github.com/stop666two/X-ReaderPlus",
  "keywords": [
    "ebook-reader",
    "vue",
    "offline",
    "epub",
    "pdf",
    "reader"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:go": "cd backend && go run .",
    "dev:wails": "wails dev",
    "build": "vite build",
    "build:go": "vite build && node scripts/copy-frontend.js && cd backend && wails build -o ../dist/X-ReaderPlus.exe && cd ..",
    "build:go:dev": "cd backend && wails build -devtools && copy /y build\\dist\\X-ReaderPlus.exe ..\\dist\\X-ReaderPlus-dev.exe >nul 2>&1",
    "build:all": "vite build && node scripts/copy-frontend.js && cd backend && wails build && (if exist build\\bin\\X-ReaderPlus.exe (copy /y build\\bin\\X-ReaderPlus.exe ..\\dist\\X-ReaderPlus.exe >nul) else (copy /y build\\dist\\X-ReaderPlus.exe ..\\dist\\X-ReaderPlus.exe >nul)) && cd ..",
    "build:wails": "cd backend && wails build",
    "postbuild": "node scripts/copy-frontend.js",
    "preview": "vite preview",
    "lint": "vue-tsc --noEmit && eslint src --quiet",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\""
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "dayjs": "^1.11.13",
    "dompurify": "^3.2.4",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "marked": "^15.0.12",
    "pdfjs-dist": "^4.0.379",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-i18n": "^11.1.1",
    "vue-router": "^4.5.1",
    "vuetify": "^3.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",

    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "prettier": "^3.5.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.3.5",
    "vue-tsc": "^3.3.8"
  }
}
